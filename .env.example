# ============================================================
#  개발 환경 설정 파일 템플릿
#  복사 후 실제 값으로 채워서 사용:  cp .env.example .env
#  .env 파일은 절대 git에 커밋하지 마세요!
# ============================================================

# PostgreSQL 비밀번호 (8자 이상)
DB_PASSWORD=

# JWT 서명용 시크릿 키 (충분히 긴 랜덤 문자열 권장)
# 생성 예시: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# 백엔드 DB 연결 URL (DB_PASSWORD와 동일한 값 사용)
DATABASE_URL=postgresql+asyncpg://apm:@localhost:5432/apmdb
